# Copy this file to .env and fill in real values. .env is gitignored.

# Required. Get one from https://console.anthropic.com/ under API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# Required for a real (non-dry-run) run. The site the agent should test —
# point this at your own site, not a placeholder domain you don't own.
TARGET_SITE_URL=https://your-site-example.com

# Optional — only needed if you want to test the email path locally with
# --send-email / SEND_EMAIL=true. Same three secrets the GitHub Actions
# workflow reads from repo secrets.
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=
ALERT_EMAIL=
